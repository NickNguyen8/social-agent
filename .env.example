# === LLM Provider ===
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # Dùng nếu chuyển provider sang OpenAI

# === Facebook Credentials (lưu 1 lần, auto-refresh mỗi tuần) ===
# Lấy App ID + Secret từ: https://developers.facebook.com → App Settings → Basic
# Lấy User Token từ: https://developers.facebook.com/tools/explorer
#   → Permissions: pages_manage_posts, pages_read_engagement, pages_show_list
#
# Sau khi điền 3 dòng này, chạy: social-agent token --app-id APP_ID --user-token EAA...
# Tokens sẽ tự ghi vào file này, lần sau chỉ cần: social-agent token --refresh-all
FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here
FB_USER_TOKEN=your_long_lived_user_token_here

# --- Page Tokens (tự động ghi bởi social-agent token) ---
FASTDX_PAGE_TOKEN=your_long_lived_page_access_token_here

# Group token - cần Group admin approve app trước
TECH_GROUP_TOKEN=your_group_access_token_here

# Chrome Profile path cho Facebook Personal Profile (Playwright)
# macOS:   /Users/yourname/Library/Application Support/Google/Chrome
# Windows: C:\Users\yourname\AppData\Local\Google\Chrome\User Data
# Linux:   /home/yourname/.config/google-chrome
FB_CHROME_PROFILE_PATH=/Users/yourname/Library/Application Support/Google/Chrome
FB_CHROME_PROFILE_DIR=Default

# === LinkedIn Tokens ===
# Lấy qua OAuth 2.0 Authorization Code flow
# App cần products: Share on LinkedIn + Sign In with LinkedIn using OpenID Connect
# Scopes: openid, profile, w_member_social (personal), w_organization_social (company page)
# Token lifetime: 60 ngày, sau đó cần refresh
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# LinkedIn Company Page token (nếu có Company Page riêng)
# Cùng token hoặc token riêng với w_organization_social scope
LINKEDIN_COMPANY_TOKEN=your_linkedin_company_token_here

# === Profile Automation (P2 Security) ===
# Automating personal Facebook profile vi phạm Facebook ToS.
# Uncomment dòng dưới và đặt = yes NẾU bạn hiểu rõ rủi ro và vẫn muốn dùng.
# ALLOW_PROFILE_AUTOMATION=yes

# === Cross-platform Paths (tùy chọn) ===
# Override đường dẫn log và config (hữu ích cho Docker/server/desktop app)
# Mặc định: platformdirs auto-detect theo OS (~/.local/share/social-agent/ trên Linux)
# SOCIAL_AGENT_LOG_DIR=/custom/path/to/logs
# SOCIAL_AGENT_CONFIG=/custom/path/to/config.yaml
